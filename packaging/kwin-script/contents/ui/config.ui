         <item row="4" column="1">
          <widget class="QLineEdit" name="kcfg_DefaultWindowHeight">
           <property name="toolTip">
            <string>Use auto for automatic height, a bare 10 to 100 or explicit 10% to 100% percentage, or a fixed 1px to 16384px logical client height. Application rules override this value. Only fresh singleton admissions and fresh retiling after a change use it; existing, restored, and transferred geometry is unchanged. Solver constraints and output pixel-grid snapping remain authoritative.</string>
           </property>
           <property name="placeholderText">
            <string>auto, 50%, or 720px</string>
