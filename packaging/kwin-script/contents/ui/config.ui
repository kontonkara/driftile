     <widget class="QWidget" name="applicationsTab">
      <attribute name="title">
       <string>Applications</string>
      </attribute>
      <layout class="QVBoxLayout" name="applicationsLayout">
       <item>
        <widget class="QLabel" name="applicationIdentifierHint">
         <property name="text">
          <string>Each application identifier is exact and case-sensitive: KWin desktopFileName when available, otherwise resourceClass.</string>
         </property>
         <property name="wordWrap">
          <bool>true</bool>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="applicationColumnPresentationsLabel">
         <property name="text">
          <string>Application column presentations:</string>
         </property>
         <property name="buddy">
          <cstring>kcfg_ApplicationColumnPresentations</cstring>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPlainTextEdit" name="kcfg_ApplicationColumnPresentations">
         <property name="toolTip">
          <string>Enter up to 128 exact, case-sensitive application identifier and presentation pairs, one per line, for example org.gnome.Evince=tabbed.</string>
         </property>
         <property name="whatsThis">
          <string>Each nonempty line selects stacked or tabbed presentation when a matching application creates a column. Use identifier=stacked or identifier=tabbed.</string>
         </property>
         <property name="minimumSize">
          <size>
           <width>0</width>
           <height>100</height>
          </size>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="applicationColumnWidthsLabel">
         <property name="text">
          <string>Application initial column widths (% or px):</string>
         </property>
         <property name="buddy">
          <cstring>kcfg_ApplicationColumnWidths</cstring>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPlainTextEdit" name="kcfg_ApplicationColumnWidths">
         <property name="toolTip">
          <string>Enter up to 128 exact, case-sensitive application identifier and width pairs, one per line, for example org.kde.konsole=60 or org.mozilla.firefox=960px.</string>
         </property>
         <property name="whatsThis">
          <string>Each nonempty line affects only fresh singleton admission. After the equals sign, use a bare 10 to 100 percentage, an explicit 10% to 100% percentage, or a fixed 1px to 16384px logical width. Fixed widths are constrained by the admitted window and snapped to the assigned output pixel grid. Existing columns and reset behavior are unchanged.</string>
         </property>
         <property name="minimumSize">
          <size>
           <width>0</width>
           <height>140</height>
          </size>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="applicationWindowHeightsLabel">
         <property name="text">
          <string>Application initial tiled client heights (% or px):</string>
         </property>
         <property name="buddy">
          <cstring>kcfg_ApplicationWindowHeights</cstring>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPlainTextEdit" name="kcfg_ApplicationWindowHeights">
         <property name="toolTip">
          <string>Enter up to 128 exact, case-sensitive application identifier and height pairs, one per line, for example org.kde.konsole=60 or org.mozilla.firefox=720px.</string>
         </property>
         <property name="whatsThis">
          <string>Each nonempty identifier=value line affects only fresh singleton tiled admission. After the equals sign, use a bare 10 to 100 percentage, an explicit 10% to 100% percentage, or a fixed 1px to 16384px logical client height. Existing, restored, and transferred geometry is unchanged. Solver constraints and output pixel-grid snapping remain authoritative.</string>
         </property>
         <property name="minimumSize">
          <size>
           <width>0</width>
           <height>140</height>
          </size>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="applicationFocusCenteringLabel">
         <property name="text">
          <string>Applications centered during horizontal focus:</string>
         </property>
         <property name="buddy">
          <cstring>kcfg_ApplicationFocusCentering</cstring>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPlainTextEdit" name="kcfg_ApplicationFocusCentering">
         <property name="toolTip">
          <string>Enter one exact, case-sensitive application identifier per line. This affects horizontal focus centering only.</string>
         </property>
         <property name="whatsThis">
          <string>Blank lines are ignored. Exact matches are centered after horizontal focus navigation.</string>
         </property>
         <property name="minimumSize">
          <size>
           <width>0</width>
           <height>80</height>
          </size>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="applicationInitialDestinationsLabel">
         <property name="text">
          <string>Application initial destinations:</string>
         </property>
         <property name="buddy">
          <cstring>kcfg_ApplicationInitialDestinations</cstring>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPlainTextEdit" name="kcfg_ApplicationInitialDestinations">
         <property name="toolTip">
          <string>Enter up to 128 exact, case-sensitive identifier=desktop-name:Work,output:DP-1 rules, one per line. Use desktop:2 or desktop-name:Work, optionally with an output. Desktop numbers are 1 to 25; desktop and output names are exact and case-sensitive.</string>
         </property>
         <property name="whatsThis">
          <string>Rules apply once to genuinely new normal windows, before initial floating, full-width, and fullscreen rules. A named desktop must match exactly one current virtual desktop. Admission writes only the new window's desktop and output assignment; it never moves an already tracked window, changes focus, or switches the current desktop. Missing, ambiguous, or rejected destinations use a safe one-shot fallback. Live edits affect future windows only.</string>
         </property>
         <property name="minimumSize">
          <size>
           <width>0</width>
           <height>120</height>
          </size>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="applicationInitialFloatingLabel">
         <property name="text">
          <string>Applications initially floating:</string>
         </property>
         <property name="buddy">
          <cstring>kcfg_ApplicationInitialFloating</cstring>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPlainTextEdit" name="kcfg_ApplicationInitialFloating">
         <property name="toolTip">
          <string>Enter one exact, case-sensitive application identifier per line.</string>
         </property>
         <property name="whatsThis">
          <string>Blank lines are ignored. New exact matches start as manually floating windows.</string>
         </property>
         <property name="minimumSize">
          <size>
           <width>0</width>
           <height>100</height>
          </size>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="applicationFloatingPositionsLabel">
         <property name="text">
          <string>Application floating positions:</string>
         </property>
         <property name="buddy">
          <cstring>kcfg_ApplicationFloatingPositions</cstring>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPlainTextEdit" name="kcfg_ApplicationFloatingPositions">
         <property name="toolTip">
          <string>Enter up to 128 exact, case-sensitive identifier=anchor,x,y rules, one per line. Anchors are top-left, top, top-right, right, bottom-right, bottom, bottom-left, or left. Offsets are signed integer logical pixels from -16384 to 16384. Rules apply when a genuinely new normal window starts manual floating or a tiled window first enters manual floating. A remembered manual position wins afterward. Startup-existing, restored, already manually floating, automatic, and dialog windows are not repositioned. Desktop and output transfers preserve the current frame. Live edits affect future first manual-floating placements only.</string>
         </property>
         <property name="whatsThis">
          <string>Rules apply when a genuinely new normal window starts manual floating or a tiled window first enters manual floating. A remembered manual position wins afterward. Startup-existing, restored, already manually floating, automatic, and dialog windows are not repositioned. Desktop and output transfers preserve the current frame. Live edits affect future first manual-floating placements only.</string>
         </property>
         <property name="minimumSize">
          <size>
           <width>0</width>
           <height>120</height>
          </size>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="applicationInitialFullWidthLabel">
         <property name="text">
          <string>Applications initially full-width:</string>
         </property>
         <property name="buddy">
          <cstring>kcfg_ApplicationInitialFullWidth</cstring>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPlainTextEdit" name="kcfg_ApplicationInitialFullWidth">
         <property name="toolTip">
          <string>Enter up to 128 exact, case-sensitive application identifiers, one per line. Genuinely new normal tiled matches open as full-width columns. Their exact application or default width remains the Meta+F restore width. Existing, restored, transferred, and freshly re-tiled windows are unchanged. Live edits affect future tracked windows and do not move current ones.</string>
         </property>
         <property name="whatsThis">
          <string>Blank lines are ignored. Only genuinely new normal tiled windows matching an exact application identifier open as full-width columns; their configured application or default width remains the Meta+F restore width. Existing, restored, transferred, and freshly re-tiled windows are unchanged. Live edits affect future tracked windows and do not move current ones.</string>
         </property>
         <property name="minimumSize">
          <size>
           <width>0</width>
           <height>100</height>
          </size>
         </property>
       </widget>
      </item>
      <item>
        <widget class="QLabel" name="applicationInitialMaximizedLabel">
         <property name="text">
          <string>Applications initially maximized:</string>
         </property>
         <property name="buddy">
          <cstring>kcfg_ApplicationInitialMaximized</cstring>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPlainTextEdit" name="kcfg_ApplicationInitialMaximized">
         <property name="toolTip">
          <string>Enter up to 128 exact, case-sensitive application identifiers, one per line. Fresh normal matches request native maximize to the work-area edges after their underlying tiled or floating admission. Startup-existing, restored, and already tracked windows remain unchanged. Unsupported or rejected maximize requests use a safe one-shot fallback. Live edits affect future tracked windows only.</string>
         </property>
         <property name="whatsThis">
          <string>Blank lines are ignored. Fresh normal exact matches request native maximize to the work-area edges after their underlying tiled or floating admission. Startup-existing, restored, and already tracked windows remain unchanged. Unsupported or rejected maximize requests fall back once without retrying. Live edits affect future tracked windows only.</string>
         </property>
         <property name="minimumSize">
          <size>
           <width>0</width>
           <height>100</height>
          </size>
         </property>
       </widget>
      </item>
      <item>
        <widget class="QLabel" name="applicationInitialFocusedLabel">
         <property name="text">
          <string>Applications initially focused:</string>
         </property>
         <property name="buddy">
          <cstring>kcfg_ApplicationInitialFocused</cstring>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPlainTextEdit" name="kcfg_ApplicationInitialFocused">
         <property name="toolTip">
          <string>Enter up to 128 exact, case-sensitive application identifiers, one per line. Fresh normal matches request focus once after admission only when their desktop and output context is already visible. The rule never selects a desktop or output and does not suppress normal KWin focus for unlisted applications. Rejected or unavailable focus requests are not retried. Live edits affect future tracked windows only.</string>
         </property>
         <property name="whatsThis">
          <string>Blank lines are ignored. Fresh normal exact matches request focus once after admission only when their desktop and output context is already visible. The rule never selects a desktop or output, leaves normal KWin focus behavior unchanged for unlisted applications, and does not retry rejected or unavailable requests. Live edits affect future tracked windows only.</string>
         </property>
         <property name="minimumSize">
          <size>
           <width>0</width>
           <height>100</height>
          </size>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="applicationInitialUnfocusedLabel">
         <property name="text">
          <string>Applications initially unfocused:</string>
         </property>
         <property name="buddy">
          <cstring>kcfg_ApplicationInitialUnfocused</cstring>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPlainTextEdit" name="kcfg_ApplicationInitialUnfocused">
         <property name="toolTip">
          <string>Enter up to 128 exact, case-sensitive application identifiers, one per line. Fresh normal matches suppress or undo initial focus once after admission only when their desktop and output context is already visible. The rule never selects a desktop or output and wins when the same application is also listed as initially focused. Rejected or unavailable one-shot requests are not retried. Live edits affect future tracked windows only.</string>
         </property>
         <property name="whatsThis">
          <string>Blank lines are ignored. Fresh normal exact matches suppress or undo initial focus once after admission only when their desktop and output context is already visible. The rule never selects a desktop or output, takes precedence over the initially focused rule, and does not retry rejected or unavailable requests. Live edits affect future tracked windows only.</string>
         </property>
         <property name="minimumSize">
          <size>
           <width>0</width>
           <height>100</height>
          </size>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="applicationInitialFullscreenLabel">
         <property name="text">
          <string>Applications initially fullscreen:</string>
         </property>
         <property name="buddy">
          <cstring>kcfg_ApplicationInitialFullscreen</cstring>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPlainTextEdit" name="kcfg_ApplicationInitialFullscreen">
         <property name="toolTip">
          <string>Enter up to 128 exact, case-sensitive application identifiers, one per line. Only genuinely new matching windows start fullscreen, and only when KWin reports that fullscreen is supported. Exiting fullscreen returns each window to its admitted tiled or floating state. Live edits affect future tracked windows only and do not rewrite existing windows.</string>
         </property>
         <property name="whatsThis">
          <string>Blank lines are ignored. Only genuinely new exact matches start fullscreen when the window supports it. Exiting fullscreen restores the tiled or floating state established during admission. Existing windows are never rewritten, and live edits affect only windows tracked in the future.</string>
         </property>
         <property name="minimumSize">
          <size>
           <width>0</width>
           <height>100</height>
          </size>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="applicationTilingExclusionsLabel">
         <property name="text">
          <string>Applications excluded from tiling:</string>
         </property>
         <property name="buddy">
          <cstring>kcfg_ApplicationTilingExclusions</cstring>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPlainTextEdit" name="kcfg_ApplicationTilingExclusions">
         <property name="toolTip">
          <string>Enter one exact, case-sensitive application identifier per line.</string>
         </property>
         <property name="whatsThis">
          <string>Blank lines are ignored. Windows matching an exact application identifier stay outside the tiled layout.</string>
         </property>
         <property name="minimumSize">
          <size>
           <width>0</width>
           <height>120</height>
          </size>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QLabel" name="applicationBorderlessExclusionsLabel">
         <property name="text">
          <string>Applications keeping KWin borders and title bars:</string>
         </property>
         <property name="buddy">
          <cstring>kcfg_ApplicationBorderlessExclusions</cstring>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QPlainTextEdit" name="kcfg_ApplicationBorderlessExclusions">
         <property name="toolTip">
          <string>Enter one exact, case-sensitive application identifier per line.</string>
         </property>
         <property name="whatsThis">
          <string>Blank lines are ignored. Exact matches keep their KWin borders and title bars.</string>
         </property>
         <property name="minimumSize">
          <size>
           <width>0</width>
           <height>120</height>
          </size>
         </property>
        </widget>
       </item>
       <item>
        <spacer name="applicationsVerticalSpacer">
         <property name="orientation">
          <enum>Qt::Vertical</enum>
         </property>
         <property name="sizeHint" stdset="0">
          <size>
           <width>20</width>
           <height>40</height>
          </size>
         </property>
        </spacer>
       </item>
      </layout>
     </widget>
    </widget>
   </item>
  </layout>
 </widget>
 <resources/>
 <connections/>
</ui>
