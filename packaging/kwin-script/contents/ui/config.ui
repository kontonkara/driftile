           </property>
          </widget>
         </item>
         <item row="5" column="1">
          <widget class="QSpinBox" name="kcfg_ColumnWidthStepPixels">
           <property name="toolTip">
            <string>Zero uses the percentage step above. A positive value changes width by fixed logical pixels without rewriting existing geometry. Window constraints and output-pixel snapping remain authoritative.</string>
           </property>
           <property name="specialValueText">
            <string>Use percentage step above</string>
           </property>
           <property name="suffix">
