            <cstring>kcfg_ColumnWidthPresets</cstring>
           </property>
          </widget>
         </item>
         <item row="6" column="1">
          <widget class="QLineEdit" name="kcfg_ColumnWidthPresets">
           <property name="toolTip">
            <string>Up to 16 comma-separated presets. Percentages use bare 10 to 100 or explicit 10% to 100%; fixed sizes use 1px to 16384px. Values must increase within each unit. Blank uses the built-in thirds.</string>
           </property>
           <property name="placeholderText">
            <string>33, 50%, 800px</string>
           </property>
          </widget>
         </item>
