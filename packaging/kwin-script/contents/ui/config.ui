          </widget>
         </item>
         <item row="13" column="1">
          <widget class="QComboBox" name="kcfg_DefaultInitialFocus">
           <property name="toolTip">
            <string>Affects genuinely new normal windows only. Exact initial-focused and initial-unfocused application rules override it; unfocused wins when both exact lists match.</string>
           </property>
           <property name="kcfg_property" stdset="0">
            <string>currentText</string>
           </property>
           <item>
            <property name="text">
