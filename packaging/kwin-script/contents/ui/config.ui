           </property>
          </widget>
         </item>
         <item row="0" column="1">
          <widget class="QPlainTextEdit" name="kcfg_NumberedDesktopTargets">
           <property name="toolTip">
            <string>Enter slot=exact desktop name pairs for slots 1 through 9, one per line. Empty slots keep positional selection.</string>
