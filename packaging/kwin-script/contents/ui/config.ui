          </widget>
         </item>
         <item row="9" column="1">
          <widget class="QLineEdit" name="kcfg_WindowHeightPresets">
           <property name="toolTip">
            <string>Up to 16 comma-separated presets. Percentages use bare 10 to 100 or explicit 10% to 100%; fixed sizes use 1px to 16384px. Values must increase within each unit. Blank uses the built-in 1/3, 1/2, and 2/3 proportions.</string>
