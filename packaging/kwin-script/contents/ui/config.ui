          </widget>
         </item>
         <item row="3" column="1">
          <widget class="QSpinBox" name="kcfg_DefaultColumnWidthPixels">
           <property name="toolTip">
            <string>Zero uses the percentage above. A positive value requests a fixed logical-pixel width for later admissions and resets; existing columns are unchanged. Solver constraints and output-pixel snapping remain authoritative.</string>
           </property>
           <property name="specialValueText">
            <string>Use percentage above</string>
           </property>
           <property name="suffix">
