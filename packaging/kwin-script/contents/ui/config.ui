     <widget class="QWidget" name="generalTab">
      <attribute name="title">
       <string>General</string>
      </attribute>
      <layout class="QVBoxLayout" name="generalLayout">
       <item>
        <widget class="QCheckBox" name="kcfg_BorderlessWindows">
         <property name="text">
          <string>Hide KWin borders and title bars on application windows</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QCheckBox" name="kcfg_CenterFocusedColumn">
         <property name="text">
          <string>Center tiled columns after horizontal focus navigation</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QCheckBox" name="kcfg_CenterFocusedColumnOnOverflow">
         <property name="text">
          <string>Center focused columns when the old and new columns do not both fit</string>
         </property>
         <property name="toolTip">
          <string>Applies only to newly focused columns. The always-center setting above takes precedence.</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QCheckBox" name="kcfg_AlwaysCenterSingleColumn">
         <property name="text">
          <string>Keep a single tiled column centered</string>
         </property>
         <property name="toolTip">
          <string>Centers the column while it is the only tiled column on the current output, desktop, and activity.</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QCheckBox" name="kcfg_ShowTabIndicator">
         <property name="text">
          <string>Show a transient OSD for tabbed-window selection</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QCheckBox" name="kcfg_TouchpadNavigation">
         <property name="text">
          <string>Enable horizontal touchpad navigation</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QCheckBox" name="kcfg_TouchpadWorkspaceNavigation">
         <property name="text">
          <string>Enable vertical touchpad desktop navigation</string>
         </property>
         <property name="toolTip">
          <string>Swipe vertically to focus the adjacent virtual desktop.</string>
         </property>
        </widget>
       </item>
       <item>
        <widget class="QCheckBox" name="kcfg_EmptyDesktopAboveFirst">
         <property name="text">
          <string>Keep an empty virtual desktop before the first occupied desktop</string>
         </property>
         <property name="toolTip">
          <string>Maintains one leading empty desktop independently of the shared trailing empty desktop.</string>
         </property>
        </widget>
       </item>
       <item>
        <layout class="QFormLayout" name="touchpadNavigationLayout">
         <item row="0" column="0">
          <widget class="QLabel" name="touchpadNavigationFingerCountLabel">
