           </property>
           <property name="buddy">
            <cstring>kcfg_WindowHeightStepPixels</cstring>
           </property>
          </widget>
         </item>
         <item row="8" column="1">
          <widget class="QSpinBox" name="kcfg_WindowHeightStepPixels">
           <property name="toolTip">
