       </item>
       <item>
        <widget class="QPlainTextEdit" name="kcfg_ApplicationColumnWidths">
         <property name="toolTip">
          <string>Enter one exact desktop-file ID and percentage per line, for example org.kde.konsole=60.</string>
         </property>
         <property name="whatsThis">
          <string>Each nonempty line sets the initial width of new columns for one application. Use desktop-file-id=percent with a percentage from 10 to 100.</string>
