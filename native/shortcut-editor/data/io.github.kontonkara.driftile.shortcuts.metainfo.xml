  <name>Driftile Shortcuts</name>
  <summary>Configure global shortcuts for Driftile</summary>
  <description>
    <p>
      Review and edit the primary and alternate global shortcuts exposed by
      Driftile in KDE Plasma.
    </p>
    <p>
      Changes are written only when Apply is pressed, and failed updates are
      rolled back to the previous assignments.
    </p>
  </description>
  <launchable type="desktop-id">io.github.kontonkara.driftile.shortcuts.desktop</launchable>
  <icon type="stock">preferences-desktop-keyboard-shortcuts</icon>
  <provides>
    <binary>driftile-shortcut-editor</binary>
  </provides>
  <url type="homepage">https://github.com/kontonkara/driftile</url>
  <url type="bugtracker">https://github.com/kontonkara/driftile/issues</url>
